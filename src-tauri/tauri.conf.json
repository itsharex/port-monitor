{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Port Monitor",
  "version": "0.3.0",
  "identifier": "com.kuhlen.port-monitor",
  "build": {
    "beforeDevCommand": "trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Port Monitor",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Kuhlen/port-monitor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBMzIwRUM5MzY0MzkzRUMKUldUc2swTTJ5UTR5V29rQTQ5S054bUtKQXNXL3lWZVNmVTlOOUh0MlI0OThuaCs2dDcxd3VDMmQK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
